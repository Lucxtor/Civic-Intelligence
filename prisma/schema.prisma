// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// A connected wallet address and their self-reported demographic profile.
model User {
  walletAddress String   @id @map("wallet_address")
  demographics  String   // JSON string: { "ageGroup": "25–34", "occupation": "Tech Worker", ... }
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("users")
}

/// Admin-managed demographic dimensions.
/// e.g. { key: "ageGroup", label: "Age Group", options: ["18–24", "25–34", ...] }
model DemographicDimension {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  options   String   // JSON string: array of option strings
  createdAt DateTime @default(now()) @map("created_at")

  @@map("demographic_dimensions")
}

/// Anonymized vote — wallet address is NEVER stored here.
model AnonymizedVote {
  id           String   @id @default(cuid())
  proposalId   String   @map("proposal_id")
  proposal     Proposal @relation(fields: [proposalId], references: [id])
  voterHash    String?  @map("voter_hash") // sha256(wallet_address + proposal_id + salt)
  demographics String   // JSON string: demographic tags only
  responses    String   // JSON string: { "fairness": 4, "feasibility": 3, ... }
  sentiment    String?  // "up" or "down"
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([proposalId, voterHash]) // Prevent double voting if hash is provided
  @@map("anonymized_votes")
}

/// A civic proposal created by admins.
model Proposal {
  id             String           @id @default(cuid())
  title          String
  category       String
  abstract       String           // JSON string: { technical: string, eli5: string }
  content        String           // Markdown
  impactMatrix   String           // JSON string: ImpactMatrix interface
  impact         String           @default("Medium")
  customMetrics  String           // JSON string: Array of metric objects
  allowComments  Boolean          @default(true)
  createdAt      DateTime         @default(now()) @map("created_at")
  votes          AnonymizedVote[]

  @@map("proposals")
}

/// Proposal categories managed by admins.
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("categories")
}
